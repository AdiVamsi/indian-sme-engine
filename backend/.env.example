# ──────────────────────────────────────────────────
# Indian SME Engine — Backend Environment Variables
# ──────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────

# PostgreSQL connection string
# Local example:  postgresql://user:password@localhost:5432/sme_engine
# Render example: postgresql://user:password@host.render.com:5432/sme_engine
DATABASE_URL=

# Secret key used to sign and verify JWT tokens.
# Use a long, random string in production (e.g. openssl rand -hex 64).
JWT_SECRET=

# How long JWT tokens stay valid. Default: 7d
# Examples: 1h, 24h, 7d, 30d
JWT_EXPIRES_IN=7d

# Port the server listens on. Render sets this automatically.
PORT=4000

# Application environment. Use "production" on Render.
NODE_ENV=development
