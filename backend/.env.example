PORT=4000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/sme_engine

# Auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# LLM classification
OPENAI_API_KEY=replace-with-openai-api-key
LLM_CLASSIFIER_MODEL=gpt-4o-mini

# WhatsApp Business Platform
WHATSAPP_TOKEN=replace-with-whatsapp-access-token
WHATSAPP_PHONE_ID=replace-with-whatsapp-phone-number-id
WHATSAPP_VERIFY_TOKEN=replace-with-whatsapp-webhook-verify-token
# Optional but recommended in production: enables POST webhook signature verification
# WHATSAPP_APP_SECRET=replace-with-meta-app-secret

# Superadmin
SUPERADMIN_PASSWORD=replace-with-a-strong-password
SUPERADMIN_SECRET=replace-with-a-long-random-superadmin-secret

# Optional platform settings
# CORS_ORIGIN=https://your-dashboard-domain.com,https://your-admin-domain.com
