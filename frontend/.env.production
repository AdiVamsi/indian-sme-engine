# Production environment reference
# This is a plain vanilla JS site with no build tool.
# There is no automatic .env processing.
#
# To point the frontend at your live backend:
#   1. Open frontend/config.js
#   2. Set SITE.api.baseUrl to your Render URL
#
# Example:
#   baseUrl: 'https://indian-sme-engine.onrender.com',

API_BASE=https://YOUR-BACKEND-URL.onrender.com
