generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  STAFF
}

enum ActivityType {
  AGENT_CLASSIFIED
  AGENT_PRIORITIZED
  FOLLOW_UP_SCHEDULED
  SLA_ALERT
  STATUS_CHANGED
  APPOINTMENT_CREATED
  AUTOMATION_ALERT
  AUTOMATION_DEMO_INTENT
  AUTOMATION_ADMISSION_INTENT
}

enum BusinessStage {
  STARTING
  WEBSITE_DESIGN
  WEBSITE_LIVE
  LEADS_ACTIVE
  AUTOMATION_ACTIVE
  SCALING
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  WON
  LOST
}

enum AppointmentStatus {
  NEW
  CONFIRMED
  CANCELLED
  COMPLETED
}

model Business {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  phone     String?
  whatsAppPhoneNumberId String?
  whatsAppDisplayPhoneNumber String?
  email     String?
  address   String?

  industry  String?   /* gym | academy | salon | restaurant | clinic | retail | other */
  city      String?
  country   String?   @default("India")
  timezone  String?   @default("Asia/Kolkata")
  currency  String?   @default("INR")
  logoUrl   String?
  stage     BusinessStage @default(STARTING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  leads         Lead[]
  services      Service[]
  testimonials  Testimonial[]
  appointments  Appointment[]
  agentConfig   AgentConfig?
}

model User {
  id           String   @id @default(cuid())

  businessId   String
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name         String
  email        String
  passwordHash String
  role         UserRole @default(OWNER)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([businessId, email])
}

model Lead {
  id         String     @id @default(cuid())

  businessId String
  business   Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name       String
  phone      String
  email      String?
  message    String?
  isActivationTest Boolean @default(false)
  status     LeadStatus @default(NEW)
  snoozedUntil DateTime?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  activities LeadActivity[]
  appointments Appointment[]
}

model Service {
  id          String   @id @default(cuid())

  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  title       String
  description String
  priceInr    Int?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Testimonial {
  id           String   @id @default(cuid())

  businessId   String
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  customerName String
  text         String
  rating       Int?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Appointment {
  id           String            @id @default(cuid())

  businessId   String
  business     Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)

  leadId       String?
  lead         Lead?             @relation(fields: [leadId], references: [id], onDelete: SetNull)

  customerName String
  phone        String
  scheduledAt  DateTime
  notes        String?
  status       AppointmentStatus @default(NEW)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AgentConfig {
  id                  String   @id @default(cuid())

  businessId          String   @unique
  business            Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  toneStyle           String   @default("professional")
  priorityRules       Json
  classificationRules Json
  followUpMinutes     Int      @default(30)
  autoReplyEnabled    Boolean  @default(false)

  createdAt           DateTime @default(now())
}

model LeadActivity {
  id        String       @id @default(cuid())

  leadId    String
  lead      Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)

  type      ActivityType
  message   String
  metadata  Json?

  createdAt DateTime     @default(now())
}
